# Flask Configuration
FLASK_APP=autoapp.py
FLASK_DEBUG=1
FLASK_ENV=development
SECRET_KEY=generate-a-secure-key-here
BCRYPT_LOG_ROUNDS=13
DEBUG_TB_ENABLED=False

# Database
# For local SQLite development (e.g., sqlite:///dev.db)
DATABASE_URL=sqlite:///dev.db

# Asset Management
# In production, set to a higher number like 31556926 (1 year)
SEND_FILE_MAX_AGE_DEFAULT=0

# Google Cloud & AI Services
# Get your Gemini API key at https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# AI Model Selection
# Recommended: gemini-2.0-flash-lite or gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash-lite

# Google Cloud Credentials (for Text-to-Speech)
# Path to your Google Service Account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=serviceAccountKey.json

# NLP Lab & Transformers Configuration
# Set to 'true' to enable local transformer-based intent detection (requires models in cache)
ENABLE_TRANSFORMER_INTENT=false
# Optional: Path to local Hugging Face model cache
# HF_HUB_CACHE=/path/to/your/cache
# Force offline mode for transformers if models are already downloaded
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# Server Configuration
GUNICORN_WORKERS=1
LOG_LEVEL=debug

